# .env.example
# ============================================================
# GitHub ETL Demo — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your actual credentials
#   docker-compose up -d postgres

# ------------------------------------------------------------
# GitHub Authentication
# ------------------------------------------------------------

# Fine-grained Personal Access Token with read access to target repositories.
# Generate at: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
# Required permissions: Contents (read), Metadata (read), Pull requests (read)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# ------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------

# PostgreSQL database name
POSTGRES_DB=github_etl

# PostgreSQL username (used by both Docker and the application)
POSTGRES_USER=etl_user

# PostgreSQL password — use a strong random value in production
POSTGRES_PASSWORD=

# PostgreSQL host (use 'localhost' for local dev, 'postgres' inside Docker Compose)
POSTGRES_HOST=localhost

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# ------------------------------------------------------------
# Dagster (optional for local dev)
# ------------------------------------------------------------

# Local Dagster home directory for instance storage and run history
# Defaults to ~/.dagster if not set
# DAGSTER_HOME=/path/to/dagster_home
